# Token di openapi.com per il registro imprese (creazione su console.openapi.com, fascia gratuita: 100 ricerche al giorno)
OPENAPI_TOKEN=

# Chiave Google Places per le attivita' locali (Google Cloud Console, fascia gratuita mensile inclusa)
GOOGLE_PLACES_API_KEY=

# Login DataForSEO per i volumi di ricerca reali (registrazione su dataforseo.com, a consumo)
DATAFORSEO_LOGIN=

# Password DataForSEO (stessa dashboard di dataforseo.com)
DATAFORSEO_PASSWORD=
